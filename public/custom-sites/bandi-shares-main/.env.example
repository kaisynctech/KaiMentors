# URL of the backend API — no trailing slash
# Local dev:   http://localhost:5000
# Production:  https://<your-railway-app>.up.railway.app  (set this in Vercel env vars)
BACKEND_URL=

# KaiMentors platform origin — use when the marketing site is on a separate domain
# e.g. https://kaimentors.vercel.app
# When set, Sign Up / Login link to /portal/bandi-shares/join-academy and /login on that origin.
NEXT_PUBLIC_PLATFORM_ORIGIN=

# Optional overrides for portal auth URLs (defaults: /join-academy and /login on custom domain)
# NEXT_PUBLIC_PORTAL_JOIN_HREF=/portal/bandi-shares/join-academy
# NEXT_PUBLIC_PORTAL_LOGIN_HREF=/portal/bandi-shares/login
